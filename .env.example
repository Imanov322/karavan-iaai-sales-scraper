# Port the HTTP server listens on (Railway sets PORT automatically)
PORT=4100

# Shared secret. Must match IAAI_SCRAPER_API_KEY in the office backend.
# If left empty, the /scrape endpoint will NOT require auth — only do this locally.
API_KEY=change-me

# Set HEADFUL=true for local debugging (you'll see the Chrome window)
HEADFUL=false

# Override Chromium location if needed (Dockerfile sets this to /usr/bin/chromium)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# IAAI buyer credentials, one pair per account. The account name passed in the
# /scrape request body is uppercased and looked up here.
# Example: account "khorasan" → IAAI_KHORASAN_USER / IAAI_KHORASAN_PASS
IAAI_KHORASAN_USER=
IAAI_KHORASAN_PASS=

IAAI_ALI_USER=
IAAI_ALI_PASS=

IAAI_MUSTAFA_USER=
IAAI_MUSTAFA_PASS=

IAAI_ONTARIO_USER=
IAAI_ONTARIO_PASS=

# Appwrite storage — Copart images are downloaded, uploaded here, and the
# resulting view URLs are returned to the office backend. Use the same
# project/bucket as karavan-office-backend.
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
# Public endpoint used to build file view URLs (defaults to https://cloud.appwrite.io/v1)
APPWRITE_PUBLIC_URL=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_STORAGE_BUCKET_ID=
APPWRITE_API_TOKEN=
